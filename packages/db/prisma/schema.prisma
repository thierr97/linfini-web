generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  position  Int      @default(0)
  active    Boolean  @default(true)
  items     Item[]
  createdAt DateTime @default(now())
}

model Item {
  id          String      @id @default(cuid())
  name        String
  description String?
  basePrice   Float
  imageUrl    String?
  imageAlt    String?
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  modifiers   Modifier[]
  orderLines  OrderLine[]
  stock       Stock[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Modifier {
  id        String  @id @default(cuid())
  name      String
  price     Float   @default(0)
  premium   Boolean @default(false)
  available Boolean @default(true)
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id])
}

model Order {
  id            String        @id @default(cuid())
  number        String        @unique
  tableId       String?
  table         Table?        @relation(fields: [tableId], references: [id])
  status        OrderStatus   @default(NEW)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod?
  total         Float
  note          String?
  posId         String?
  lines         OrderLine[]
  payment       Payment?
  sentAt        DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderLine {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  itemId    String
  item      Item   @relation(fields: [itemId], references: [id])
  quantity  Int    @default(1)
  unitPrice Float
  modifiers Json
  note      String?
}

enum OrderStatus {
  NEW
  PREP
  READY
  SERVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
}

model Table {
  id       String  @id @default(cuid())
  number   String  @unique
  label    String
  capacity Int     @default(4)
  active   Boolean @default(true)
  qrCode   String?
  posX     Int     @default(0)
  posY     Int     @default(0)
  orders   Order[]
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  method      PaymentMethod
  amount      Float
  cashGiven   Float?
  cashChange  Float?
  cardRef     String?
  createdAt   DateTime      @default(now())
}

model CashMovement {
  id        String        @id @default(cuid())
  type      CashMoveType
  amount    Float
  reason    String
  userId    String?
  createdAt DateTime      @default(now())
}

enum CashMoveType {
  IN
  OUT
}

model Stock {
  id        String          @id @default(cuid())
  name      String
  unit      String          @default("unité")
  quantity  Float           @default(0)
  minQty    Float           @default(0)
  alert     Boolean         @default(false)
  itemId    String?
  item      Item?           @relation(fields: [itemId], references: [id])
  movements StockMovement[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model StockMovement {
  id        String        @id @default(cuid())
  stockId   String
  stock     Stock         @relation(fields: [stockId], references: [id])
  type      StockMoveType
  quantity  Float
  reason    String?
  orderId   String?
  createdAt DateTime      @default(now())
}

enum StockMoveType {
  IN
  OUT
  ADJUSTMENT
}

model Contractor {
  id        String              @id @default(cuid())
  firstName String
  lastName  String
  phone     String?
  email     String?
  role      String?
  payments  ContractorPayment[]
  createdAt DateTime            @default(now())
}

model ContractorPayment {
  id           String        @id @default(cuid())
  contractorId String
  contractor   Contractor    @relation(fields: [contractorId], references: [id])
  amount       Float
  description  String
  method       PaymentMethod @default(CASH)
  eventId      String?
  event        Event?        @relation(fields: [eventId], references: [id])
  createdAt    DateTime      @default(now())
}

model Reservation {
  id        String            @id @default(cuid())
  name      String
  email     String
  phone     String
  date      DateTime
  guests    Int
  note      String?
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Event {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  description   String?      @db.Text
  shortDesc     String?
  date          DateTime
  doorsOpen     DateTime?
  endDate       DateTime?
  venue         String       @default("L'Infini Club")
  imageUrl      String?
  bannerUrl     String?
  lineup        Json?
  dressCode     String?
  ageRestriction Int?
  published     Boolean      @default(false)
  featured      Boolean      @default(false)
  soldOut       Boolean      @default(false)
  categories    String[]
  ticketTypes         TicketType[]
  tickets             Ticket[]
  contractorPayments  ContractorPayment[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  quantity    Int
  sold        Int      @default(0)
  maxPerOrder Int      @default(10)
  salesStart  DateTime?
  salesEnd    DateTime?
  includes    String[]
  active      Boolean  @default(true)
  position    Int      @default(0)
  tickets     Ticket[]
}

model Ticket {
  id              String       @id @default(cuid())
  code            String       @unique @default(cuid())
  eventId         String
  event           Event        @relation(fields: [eventId], references: [id])
  ticketTypeId    String
  ticketType      TicketType   @relation(fields: [ticketTypeId], references: [id])
  buyerEmail      String
  buyerFirstName  String
  buyerLastName   String
  buyerPhone      String?
  quantity        Int          @default(1)
  unitPrice       Float
  total           Float
  status          TicketStatus @default(RESERVED)
  stripeSessionId String?
  stripePaymentId String?
  scannedAt       DateTime?
  createdAt       DateTime     @default(now())
}

enum TicketStatus {
  RESERVED
  PAID
  CONFIRMED
  USED
  CANCELLED
  REFUNDED
}

// Commande click & collect payée en ligne sur infinigp.fr
// code = code de retrait 6 chiffres (affiché au client, scanné au bar)
model PickupOrder {
  id              String      @id @default(cuid())
  code            String      @unique
  stripeSessionId String      @unique
  customerName    String
  customerEmail   String?
  note            String?
  lines           Json
  total           Float
  status          OrderStatus @default(NEW)
  odooOrderId     Int?
  odooRef         String?
  odooError       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ── Emailing / Newsletter clients ──────────────────────────────────────────────
// Liste opt-in des clients L'Infini (RGPD : désinscription + suppression bounces)
model EmailContact {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  source           String?   // reservation | ticket | pickup | client | import
  subscribed       Boolean   @default(true)
  unsubscribeToken String    @unique @default(cuid())
  unsubscribedAt   DateTime?
  bounced          Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model EmailCampaign {
  id          String      @id @default(cuid())
  subject     String
  preheader   String?
  body        String      @db.Text
  status      String      @default("DRAFT") // DRAFT | SENDING | SENT
  totalCount  Int         @default(0)
  sentCount   Int         @default(0)
  failedCount Int         @default(0)
  openCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  sentAt      DateTime?
  sends       EmailSend[]
}

model EmailSend {
  id         String        @id @default(cuid())
  campaignId String
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email      String
  status     String        @default("PENDING") // SENT | FAILED
  error      String?
  sentAt     DateTime?
  openedAt   DateTime?

  @@unique([campaignId, email])
}

model Setting {
  key   String @id
  value String
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  role     String  @default("ADMIN")
  name     String?
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  telephone String?
  password  String
  discount  Int      @default(0)
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
